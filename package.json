{
  "name": "wbc-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n NEXT,ADMIN -c blue,green \"next dev\" \"npm run dev:admin\"",
    "dev:next": "next dev",
    "dev:admin": "cd backend && .venv\\Scripts\\python manage.py runserver 127.0.0.1:8000",
    "setup": "powershell -ExecutionPolicy Bypass -File backend/setup.ps1",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.0",
    "lucide-react": "^0.400.0",
    "motion": "^11.3.0",
    "next": "^15.5.18",
    "react": "^18",
    "react-dom": "^18",
    "react-use-measure": "^2.1.7",
    "tailwind-merge": "^2.4.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "eslint": "^8",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
